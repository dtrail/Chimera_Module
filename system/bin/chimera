#!/system/bin/sh
# Helper Tool for Chimera Familia

case "$1" in
    on|1|enable)
        setprop persist.chimera.enable 1
        echo "Chimera enabled."
        ;;
    off|0|disable)
        setprop persist.chimera.enable 0
        echo "Chimera disabled (Master Kill Switch)."
        ;;
    debug)
        # Debug Toggle Logik
        case "$2" in
            on|1)
                if [ -w "/sys/kernel/chimera_doom/debug" ]; then
                    echo 1 > /sys/kernel/chimera_doom/debug
                    echo "Chimera Debug Logging: ENABLED (Check dmesg)"
                else
                    echo "Error: Kernel module not loaded or read-only."
                fi
                ;;
            off|0)
                if [ -w "/sys/kernel/chimera_doom/debug" ]; then
                    echo 0 > /sys/kernel/chimera_doom/debug
                    echo "Chimera Debug Logging: DISABLED"
                else
                    echo "Error: Kernel module not loaded."
                fi
                ;;
            *)
                echo "Usage: chimera debug [on|off]"
                ;;
        esac
        ;;
    status)
        STATE=$(getprop persist.chimera.enable)
        
        # Check ob Kernel Modul läuft
        if [ -f "/sys/kernel/chimera_doom/active" ]; then
            KERNEL=$(cat /sys/kernel/chimera_doom/active)
            DEBUG=$(cat /sys/kernel/chimera_doom/debug)
            
            # Zeige an, ob die Blocklist Inhalt hat
            if [ -f "/sys/kernel/chimera_doom/blocklist" ]; then
                BL_CONTENT=$(cat /sys/kernel/chimera_doom/blocklist)
                if [ -z "$BL_CONTENT" ]; then
                    BL_STATUS="Empty"
                else
                    BL_STATUS="Loaded"
                fi
            else
                BL_STATUS="Error (Node missing)"
            fi
        else
            KERNEL="N/A (Module Error)"
            DEBUG="N/A"
            BL_STATUS="N/A"
        fi
        
        echo "--------------------------------"
        echo "Master Switch: $STATE"
        echo "Kernel Block:  $KERNEL"
        echo "Debug Mode:    $DEBUG"
        echo "Blocklist:     $BL_STATUS"
        echo "--------------------------------"
        ;;
    *)
        echo "Usage: chimera [on | off | status | debug on/off]"
        ;;
esac
